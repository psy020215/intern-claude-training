{
  "permissions": {
    "allow": [
      "Bash(git commit *)",
      "Bash(echo \"exit:$?\")",
      "Bash(jupyter nbconvert *)",
      "Bash(python3 *)",
      "Bash(git add)",
      "Bash(git add *)",
      "Bash(git push *)",
      "Bash(git -C /workspaces/intern-claude-training diff --stat notebooks/03_ngs_pipeline_with_claude.ipynb)",
      "Bash(timeout 20 /opt/conda/envs/sbml/bin/python notebooks/makegff.py SRR1168121_sorted.bam /tmp/claude-1000/-workspaces-intern-claude-training/52a2caf6-6d87-4429-858f-5506d4a94bd3/scratchpad/out.gff)",
      "Bash(echo \"EXIT:$?\")",
      "Bash(echo \"EXIT: $?\")",
      "Bash(xxd chipexo.gff)",
      "Bash(gzip -k -f chipexo.gff)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; [ -f \"$f\" ] && git -C \"$(dirname \"$f\")\" add -- \"$f\" && git -C \"$(dirname \"$f\")\" commit -m \"auto: update $(basename \"$f\")\" --quiet && git -C \"$(dirname \"$f\")\" push origin HEAD --quiet; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
